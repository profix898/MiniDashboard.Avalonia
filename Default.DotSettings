	<s:String x:Key="/Default/CodeStyle/Naming/CSharpNaming/UserRules/=056a9fae_002D6d24_002D4615_002D825c_002Dd08b2aa5d0f1/@EntryIndexedValue">&lt;Policy&gt;&lt;Descriptor Staticness="Instance" AccessRightKinds="Private, Protected" Description="VS GUI Events"&gt;&lt;ElementKinds&gt;&lt;Kind Name="METHOD" /&gt;&lt;/ElementKinds&gt;&lt;/Descriptor&gt;&lt;Policy Inspect="True" Prefix="" Suffix="" Style="AaBb_AaBb"&gt;&lt;ExtraRule Prefix="" Suffix="_Click" Style="aaBb" /&gt;&lt;ExtraRule Prefix="" Suffix="_DoubleClick" Style="aaBb" /&gt;&lt;ExtraRule Prefix="" Suffix="_ButtonClick" Style="aaBb" /&gt;&lt;ExtraRule Prefix="" Suffix="_SelectedIndexChanged" Style="aaBb" /&gt;&lt;ExtraRule Prefix="" Suffix="_CheckedChanged" Style="aaBb" /&gt;&lt;ExtraRule Prefix="" Suffix="_MouseHover" Style="aaBb" /&gt;&lt;ExtraRule Prefix="" Suffix="_Resize" Style="aaBb" /&gt;&lt;ExtraRule Prefix="" Suffix="_DropDownItemClicked" Style="aaBb" /&gt;&lt;/Policy&gt;&lt;/Policy&gt;</s:String>
	
