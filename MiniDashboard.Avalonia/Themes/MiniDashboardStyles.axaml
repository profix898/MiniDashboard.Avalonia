<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:MiniDashboard.Avalonia.Converters"
        xmlns:controls="clr-namespace:MiniDashboard.Avalonia"
        x:Class="MiniDashboard.Avalonia.Themes.MiniDashboardStyles">

    <Styles.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://MiniDashboard.Avalonia/Themes/Colors.axaml" />
                <ResourceInclude Source="avares://MiniDashboard.Avalonia/Themes/Controls/Tile.axaml" />
                <ResourceInclude Source="avares://MiniDashboard.Avalonia/Themes/Controls/TextTile.axaml" />
                <ResourceInclude Source="avares://MiniDashboard.Avalonia/Themes/Controls/ImageTile.axaml" />
                <ResourceInclude Source="avares://MiniDashboard.Avalonia/Themes/Controls/TableViewTile.axaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:InverseBooleanConverter x:Key="InverseBoolConverter" />
            <converters:TopCornersOnlyCornerRadiusConverter x:Key="TopCornersOnlyConverter" />
        </ResourceDictionary>
    </Styles.Resources>

    <!-- Global DashboardPanel styling using themed brushes -->
    <Style Selector="controls|DashboardPanel">
        <Setter Property="ColumnFillA" Value="{DynamicResource DashboardColumnFillABrush}" />
        <Setter Property="ColumnFillB" Value="{DynamicResource DashboardColumnFillBBrush}" />
        <Setter Property="RowFill" Value="{DynamicResource DashboardRowFillBrush}" />
        <Setter Property="GridLineBrush" Value="{DynamicResource DashboardGridLineBrush}" />
        <Setter Property="TileMargin" Value="6" />
        <Setter Property="TileCornerRadius" Value="6" />
        <Setter Property="TileBorderBrush" Value="{DynamicResource TileBorderBrush}" />
        <Setter Property="TileBorderThickness" Value="1" />
    </Style>

    <!-- Tiles bind Tile properties to global DashboardPanel properties -->
        <Style Selector="controls|DashboardPanel > :is(controls|Tile)">
        <Setter Property="CornerRadius"
                Value="{Binding TileCornerRadius, RelativeSource={RelativeSource AncestorType=controls:DashboardPanel}}" />
        <Setter Property="BorderBrush"
                Value="{Binding TileBorderBrush, RelativeSource={RelativeSource AncestorType=controls:DashboardPanel}}" />
        <Setter Property="BorderThickness"
                Value="{Binding TileBorderThickness, RelativeSource={RelativeSource AncestorType=controls:DashboardPanel}}" />
    </Style>
        <Style Selector="controls|DashboardPanel > :is(controls|TextTile)">
        <Setter Property="CornerRadius"
                Value="{Binding TileCornerRadius, RelativeSource={RelativeSource AncestorType=controls:DashboardPanel}}" />
        <Setter Property="BorderBrush"
                Value="{Binding TileBorderBrush, RelativeSource={RelativeSource AncestorType=controls:DashboardPanel}}" />
        <Setter Property="BorderThickness"
                Value="{Binding TileBorderThickness, RelativeSource={RelativeSource AncestorType=controls:DashboardPanel}}" />
    </Style>
        <Style Selector="controls|DashboardPanel > :is(controls|ImageTile)">
        <Setter Property="CornerRadius"
                Value="{Binding TileCornerRadius, RelativeSource={RelativeSource AncestorType=controls:DashboardPanel}}" />
        <Setter Property="BorderBrush"
                Value="{Binding TileBorderBrush, RelativeSource={RelativeSource AncestorType=controls:DashboardPanel}}" />
        <Setter Property="BorderThickness"
                Value="{Binding TileBorderThickness, RelativeSource={RelativeSource AncestorType=controls:DashboardPanel}}" />
    </Style>
        <Style Selector="controls|DashboardPanel > :is(controls|TableViewTile)">
        <Setter Property="CornerRadius"
            Value="{Binding TileCornerRadius, RelativeSource={RelativeSource AncestorType=controls:DashboardPanel}}" />
        <Setter Property="BorderBrush"
            Value="{Binding TileBorderBrush, RelativeSource={RelativeSource AncestorType=controls:DashboardPanel}}" />
        <Setter Property="BorderThickness"
            Value="{Binding TileBorderThickness, RelativeSource={RelativeSource AncestorType=controls:DashboardPanel}}" />
        </Style>

    <!-- Resize grip is subtle at rest and reveals on hover to guide the eye to the active corner.
         Uses :is() so it applies to every tile type (TextTile, ImageTile, PlotTile, TreeDataGridTile, ...) across all assemblies. -->
    <Style Selector=":is(controls|Tile) /template/ Thumb#PART_ResizeThumb">
        <Setter Property="Opacity" Value="0.45" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.12" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector=":is(controls|Tile):pointerover /template/ Thumb#PART_ResizeThumb">
        <Setter Property="Opacity" Value="1" />
    </Style>

</Styles>