<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:media="clr-namespace:MiniDashboard.Avalonia">

    <ControlTheme x:Key="{x:Type media:ImageTile}" TargetType="media:ImageTile">
        <Setter Property="TileHeader" Value="Image" />
        <Setter Property="TileBackground" Value="{DynamicResource TileBackgroundBrush}" />
        <Setter Property="TileForeground" Value="{DynamicResource TileForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource TileBorderBrush}" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding TileBackground}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                IsVisible="{TemplateBinding IsHeaderVisible}"
                                Background="{DynamicResource TileHeaderBackgroundBrush}"
                                Padding="8"
                                CornerRadius="{Binding CornerRadius, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource TopCornersOnlyConverter}}"
                                media:DraggableBehavior.IsEnabled="True"
                                Cursor="SizeAll">
                            <Grid>
                                <ContentPresenter x:Name="PART_HeaderPresenter"
                                                  Content="{TemplateBinding HeaderContent}"
                                                  ContentTemplate="{TemplateBinding HeaderTemplate}" />
                                <Border x:Name="PART_InvalidTint"
                                        Background="#7FEF4444"
                                        IsVisible="{Binding IsPlacementValid, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource InverseBoolConverter}}" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Padding="{TemplateBinding Padding}">
                            <Image Source="{TemplateBinding ImageSource}"
                                   Stretch="{TemplateBinding Stretch}"
                                   StretchDirection="{TemplateBinding StretchDirection}"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch" />
                        </Border>

                        <Thumb Grid.Row="1" x:Name="PART_ResizeThumb_HitArea"
                               IsVisible="{TemplateBinding IsResizable}"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Bottom"
                               Margin="0"
                               Width="48" Height="48"
                               Background="Transparent"
                               Cursor="BottomRightCorner"
                               ZIndex="1000" />

                        <Thumb Grid.Row="1" x:Name="PART_ResizeThumb"
                               IsVisible="{TemplateBinding IsResizable}"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Bottom"
                               Margin="3"
                               Width="18" Height="18"
                               Cursor="BottomRightCorner">
                            <Thumb.Template>
                                <ControlTemplate>
                                    <Canvas Width="18" Height="18">
                                        <Path Stroke="{DynamicResource TileForegroundBrush}"
                                              StrokeThickness="1.5"
                                              Data="M 4 15 L 15 4 M 8 15 L 15 8 M 12 15 L 15 12" />
                                    </Canvas>
                                </ControlTemplate>
                            </Thumb.Template>
                        </Thumb>

                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>
    </ControlTheme>

</ResourceDictionary>